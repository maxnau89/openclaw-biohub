# openclaw-biohub environment variables
# Copy to .env (or .env.local for the dashboard) and fill in.
#
# For most adapters the recommended setup path is `biohub connect <slug>`,
# which prompts for credentials interactively and writes them to
# $OPENCLAW_BIOHUB_HOME/secrets/<slug>.json. The variables below are the
# env-var layer underneath the CLI; only OPENCLAW_BIOHUB_HOME is
# required for normal operation.
#
# Defaults assume the systemd layout (OPENCLAW_BIOHUB_HOME=/opt/openclaw-biohub).
# For local development, point it at a writable directory you control.

# ─── Filesystem layout ──────────────────────────────────────────────────────

# Base directory. Everything else defaults to a subdir of this.
OPENCLAW_BIOHUB_HOME=/opt/openclaw-biohub

# Individual overrides (optional — comment out to use the defaults above)
# HEALTH_DB_PATH=/opt/openclaw-biohub/data/health.db
# WHOOP_DB_PATH=/opt/openclaw-biohub/data/whoop_raw.db
# OURA_DB_PATH=/opt/openclaw-biohub/data/oura_raw.db
# FITBIT_DB_PATH=/opt/openclaw-biohub/data/fitbit_raw.db
# APPLE_HEALTH_DB_PATH=/opt/openclaw-biohub/data/apple_health_raw.db
# GARMIN_DB_PATH=/opt/openclaw-biohub/data/garmin_raw.db
# OPENCLAW_BIOHUB_SECRETS_DIR=/opt/openclaw-biohub/secrets
# OPENCLAW_BIOHUB_PIPELINE_DIR=/opt/openclaw-biohub/pipeline
# OPENCLAW_BIOHUB_LOG_DIR=/opt/openclaw-biohub/logs

# ─── WHOOP OAuth ────────────────────────────────────────────────────────────
# Get these from https://developer.whoop.com (create an app).
# WHOOP uses a long-running systemd-managed OAuth handler service
# (see systemd/whoop-oauth-handler.service) rather than the in-process
# `biohub connect` flow that other adapters use.

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://YOUR_HOST/whoop/callback

# Ports the OAuth handler and webhook receiver listen on locally. Defaults
# match the systemd unit / nginx examples.
WHOOP_PORT=8893
WHOOP_WEBHOOK_PORT=8889
WHOOP_REFRESH_URL=http://127.0.0.1:8893/refresh

# ─── Fitbit OAuth ───────────────────────────────────────────────────────────
# Client ID and secret are saved into $OPENCLAW_BIOHUB_HOME/secrets/fitbit.json
# by `biohub connect fitbit` — no env vars needed for normal use.
# Override the localhost callback port if 8894 is taken:
# FITBIT_CALLBACK_PORT=8894

# ─── Oura ───────────────────────────────────────────────────────────────────
# PAT lives in $OPENCLAW_BIOHUB_HOME/secrets/oura.json after `biohub connect oura`.
# No env vars required.

# ─── Apple Health ───────────────────────────────────────────────────────────
# Watch directory path stored in $OPENCLAW_BIOHUB_HOME/secrets/apple-health.json.
# No env vars required.

# ─── Garmin (experimental) ─────────────────────────────────────────────────
# Tokens cached at $OPENCLAW_BIOHUB_HOME/secrets/garmin/ (a directory, not a
# single file — garth writes multiple token files there). Requires the
# `garth` package: pip install garth.

# ─── Anthropic API (optional, used by /api/supplements/import-amazon) ──────
# Only needed if you want LLM-assisted supplement-stack import from
# Amazon order histories. Without it, that feature is disabled.

ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
